# Streamlit Cloud secrets template.
# Copia QUESTI valori (senza i placeholder) nella UI di Streamlit Cloud:
#   Manage app → Settings → Secrets
#
# In locale, NON usare questo file: usa .env (già in .gitignore).

APP_PASSWORD = "scegli-una-password-condivisa"

# Database Postgres (es. Supabase connection pooling URI):
DATABASE_URL = "postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# API key dei provider LLM:
ANTHROPIC_API_KEY = ""
OPENAI_API_KEY = ""
GOOGLE_API_KEY = ""
PERPLEXITY_API_KEY = ""

# Opzionale: webhook Slack per alerting
SLACK_WEBHOOK_URL = ""
